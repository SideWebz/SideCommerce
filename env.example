# =============================================================================
# SideCommerce — Environment Variables Reference
# Copy this file to .env (or .env.local) and fill in the values.
# Never commit your actual .env files to git.
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/sidecommerce"

# --- Platform domains (comma-separated) ---
# The domain(s) where the SideCommerce admin panel is hosted.
# Set this to your production hostname so login redirects correctly.
# Example production value: PLATFORM_DOMAINS=sidecommerce.be
# Example with multiple:    PLATFORM_DOMAINS=sidecommerce.be,admin.sidecommerce.be
PLATFORM_DOMAINS=

# --- Admin base URL ---
# Full URL of the admin panel. Used to redirect store-owner logins back to admin
# when they log in from a storefront custom domain instead of the platform domain.
# Example: ADMIN_BASE_URL=https://sidecommerce.be
ADMIN_BASE_URL=

# --- App URL ---
# Full public URL of the app. Used in generated links (e.g. in emails).
# Example: APP_URL=https://sidecommerce.be
APP_URL=

# --- Payments (Mollie) ---
MOLLIE_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
# Base domain used for per-store sender addresses: no-reply@storename.yourdomain.com
MAIL_FROM_BASE_DOMAIN=
MAIL_FROM_LOCAL_PART=no-reply
